{
  "name": "thepubmarket",
  "version": "0.0.0",
  "private": true,
  "description": "The Pub Market — marketplace curado de TCG (Cloudflare-first, sin custodia de fondos)",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:up": "bash scripts/dev.sh",
    "dev": "turbo run dev --filter=!@thepubmarket/pitch",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "deploy": "turbo run deploy",
    "inventory:load:local": "node scripts/load-inventory.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
