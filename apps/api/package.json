{
  "name": "@thepubmarket/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply thepubmarket-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply thepubmarket-db --remote",
    "db:seed:local": "wrangler d1 execute thepubmarket-db --local --file=seed.sql",
    "db:seed:remote": "wrangler d1 execute thepubmarket-db --remote --file=seed.sql"
  },
  "dependencies": {
    "@thepubmarket/db": "workspace:*",
    "@thepubmarket/shared": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.6.0",
    "stripe": "^22.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.83.0"
  }
}
